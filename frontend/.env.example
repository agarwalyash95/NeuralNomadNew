NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_ENVIRONMENT=development

# Google Maps JavaScript API (browser key) — required for the planner map.
# Create/restrict in Google Cloud Console (HTTP referrer restriction recommended).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key_here

# Set to 1 to stream chat replies over SSE (falls back to classic POST on error)
NEXT_PUBLIC_CHAT_STREAMING=1
