SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ENVIRONMENT=development

# Absolute base URL this backend is reachable at (used to build fully-qualified
# URLs, e.g. the photo proxy, for values persisted to the database)
BACKEND_BASE_URL=http://localhost:8000

# Database — PostgreSQL only (docker-compose pgvector image). No engine
# toggle exists: dev, tests, and production all run the same engine.
# No default is supplied for DB_PASSWORD; the app fails to authenticate
# rather than silently falling back to a real credential.
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AWS (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# Sentry (Optional)
SENTRY_DSN=
